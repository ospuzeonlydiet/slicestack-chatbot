# Copy this to .env for local dev (never commit .env)
# Add all of these as Environment Variables in Vercel dashboard too

# OpenAI — you already have this
OPENAI_API_KEY=sk-...

# Supabase — get from: supabase.com → your project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # use the service_role key (not anon key)

# Slack — optional but recommended. Get from: api.slack.com → Incoming Webhooks
# Create a #leads channel and paste the webhook URL here
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
